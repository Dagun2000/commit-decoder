# LLM provider switch: "openai" (default) or "local"
LLM_PROVIDER='openai'

# Report output language: "ko" (default) or "en"
REPORT_LANGUAGE='ko'

# Required when LLM_PROVIDER=openai 
OPENAI_API_KEY=

# Required when LLM_PROVIDER=local - Ollama model tags (e.g. qwen2.5-coder:7b)
LOCAL_STAGE1_MODEL=
LOCAL_STAGE2_MODEL=
